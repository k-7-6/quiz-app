.container { padding: 20rpx; }
.setup-card { text-align: center; }
.setup-title { font-size: 38rpx; font-weight: 700; margin-bottom: 8rpx; }
.setup-desc { color: #9ca3af; font-size: 26rpx; margin-bottom: 30rpx; }
.section-chips { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 24rpx; }
.chip { padding: 16rpx 28rpx; border: 2rpx solid #d1d5db; border-radius: 30rpx; font-size: 26rpx; }
.chip.checked { background: #eef2ff; border-color: #4f46e5; color: #4f46e5; font-weight: 600; }
.form-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 24rpx; }
.form-row input { flex: 1; border: 2rpx solid #d1d5db; border-radius: 12rpx; padding: 16rpx; text-align: center; }
.btn-full { width: 100%; padding: 28rpx; font-size: 34rpx; border-radius: 20rpx; }
.progress-bar { display: flex; align-items: center; gap: 16rpx; padding: 20rpx; background: #fff; border-radius: 16rpx; margin-bottom: 20rpx; font-size: 26rpx; }
.progress-bar progress { flex: 1; }
.quiz-card { padding: 36rpx; }
.quiz-card.correct { border: 3rpx solid #16a34a; background: #f0fdf4; }
.quiz-card.wrong { border: 3rpx solid #dc2626; background: #fef2f2; }
.q-type { font-size: 24rpx; color: #9ca3af; }
.q-text { font-size: 34rpx; font-weight: 600; margin: 16rpx 0 28rpx; line-height: 1.6; }
.option { padding: 24rpx; margin-bottom: 16rpx; background: #f9fafb; border: 2rpx solid #e5e7eb; border-radius: 18rpx; font-size: 30rpx; }
.option.selected { border-color: #4f46e5; background: #eef2ff; color: #4f46e5; font-weight: 600; }
.option.correct-answer { border-color: #16a34a; background: #dcfce7; color: #166534; font-weight: 600; }
.option.wrong-answer { border-color: #dc2626; background: #fef2f2; color: #991b1b; }
.text-input { border: 2rpx solid #d1d5db; border-radius: 16rpx; padding: 24rpx; width: 100%; margin-bottom: 16rpx; font-size: 32rpx; }
.nav-btns { display: flex; gap: 16rpx; margin-top: 24rpx; }
.nav-btns button { flex: 1; }
.modal { position: fixed; inset: 0; background: rgba(0,0,0,.4); display: flex; align-items: center; justify-content: center; z-index: 100; }
.modal-content { background: #fff; border-radius: 24rpx; padding: 48rpx; width: 85%; text-align: center; }
.score-circle { width: 200rpx; height: 200rpx; border-radius: 50%; margin: 0 auto 24rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; border: 8rpx solid #4f46e5; }
.score-circle.excellent { border-color: #16a34a; color: #16a34a; }
.score-circle.good { border-color: #4f46e5; color: #4f46e5; }
.score-circle.fair { border-color: #f59e0b; color: #f59e0b; }
.score-circle.poor { border-color: #dc2626; color: #dc2626; }
.score-circle .big { font-size: 72rpx; font-weight: 800; }
.score-circle .small { font-size: 24rpx; }
.grade-text { font-size: 36rpx; font-weight: 700; margin-bottom: 16rpx; }
.result-detail { display: flex; justify-content: center; gap: 32rpx; margin-bottom: 24rpx; font-size: 28rpx; }
