<!-- 题目编辑页 -->
<view class="container">
  <view class="form-group"><text>题目类型</text>
    <picker range="{{types}}" value="{{typeIndex}}" bindchange="onType">{{types[typeIndex]}}</picker>
  </view>
  <view class="form-group"><text>分值</text><input type="number" value="{{points}}" bindinput="onPoints"/></view>
  <view class="form-group"><text>题目内容</text><textarea value="{{title}}" bindinput="onTitle" placeholder="输入题目内容..."/></view>
  <view class="form-group" wx:if="{{showOptions}}"><text>选项</text>
    <view class="option-row" wx:for="{{options}}" wx:key="index">
      <text>{{item.letter}}.</text><input value="{{item.text}}" data-idx="{{index}}" bindinput="onOpt"/>
    </view>
    <button bindtap="addOpt" wx:if="{{type !== 'truefalse'}}">+ 添加选项</button>
  </view>
  <view class="form-group"><text>正确答案</text>
    <block wx:if="{{type === 'truefalse'}}">
      <view class="chip {{answer==='对'?'selected':''}}" data-v="对" bindtap="setAnswer">✅ 对</view>
      <view class="chip {{answer==='错'?'selected':''}}" data-v="错" bindtap="setAnswer">❌ 错</view>
    </block>
    <block wx:elif="{{type === 'fillblank' || type === 'essay'}}">
      <input value="{{answer}}" bindinput="onAnswer" placeholder="输入正确答案"/>
    </block>
    <block wx:else>
      <view class="chip {{item.selected?'selected':''}}" wx:for="{{options}}" wx:key="index"
            data-idx="{{index}}" bindtap="toggleAnswer">{{item.letter}}. {{item.text}}</view>
    </block>
  </view>
  <view class="form-group"><text>解析（可选）</text><textarea value="{{explanation}}" bindinput="onExp"/></view>
  <button class="btn-primary" bindtap="save">💾 保存题目</button>
</view>
