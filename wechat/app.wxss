/* 全局样式 */
page {
  --primary: #4f46e5;
  --primary-light: #6366f1;
  --primary-bg: #eef2ff;
  --success: #16a34a;
  --success-bg: #dcfce7;
  --danger: #dc2626;
  --danger-bg: #fef2f2;
  --warning: #f59e0b;
  --gray-100: #f3f4f6;
  --gray-300: #d1d5db;
  --gray-500: #6b7280;
  --gray-700: #374151;

  font-family: -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  color: #1f2937;
  background: #f9fafb;
  box-sizing: border-box;
}

/* 通用按钮 */
.btn-primary {
  background: var(--primary);
  color: #fff;
  border-radius: 16rpx;
  padding: 24rpx 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  border: none;
}
.btn-outline {
  background: #fff;
  color: var(--gray-700);
  border: 2rpx solid var(--gray-300);
  border-radius: 16rpx;
  padding: 24rpx 40rpx;
  font-size: 30rpx;
  text-align: center;
}
.btn-success { background: var(--success); color: #fff; }

/* 卡片 */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

/* 题型标签 */
.type-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 600;
}
.type-single { background: #eef2ff; color: #4f46e5; }
.type-multiple { background: #f3e8ff; color: #7c3aed; }
.type-truefalse { background: #fffbeb; color: #d97706; }
.type-fillblank { background: #ecfdf5; color: #059669; }
.type-essay { background: #fdf2f8; color: #db2777; }

/* 正确/错误反馈 */
.feedback-correct {
  background: var(--success-bg);
  border: 2rpx solid #bbf7d0;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 20rpx;
}
.feedback-wrong {
  background: var(--danger-bg);
  border: 2rpx solid #fecaca;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  color: #9ca3af;
}
.empty-state .icon { font-size: 100rpx; }
